#!/usr/bin/env node
'use strict';

/**
 * mail-man  —  Lightweight Postman alternative
 * CLI entry point.
 */

const { Command } = require('commander');
const chalk       = require('chalk');
const path        = require('path');
const fs          = require('fs-extra');
const { ensureDirs, DATA_DIR } = require('../src/models/db');

const program = new Command();

program
  .name('mm')
  .description(chalk.bold.blue('✉  mail-man') + ' — Lightweight Postman alternative')
  .version('1.0.0', '-v, --version', 'Print version')
  .helpOption('-h, --help', 'Show help');

// ─────────────────────────────────────────────────────────────
//  mm ls
//  List every collection + its requests as a tree
// ─────────────────────────────────────────────────────────────

program
  .command('ls')
  .description('List all collections and requests as a tree')
  .addHelpText('after', '\nExample:\n  mm ls')
  .action(async () => {
    const { ls } = require('../src/controllers/LsController');
    await ls();
  });

// ─────────────────────────────────────────────────────────────
//  mm hit <collection/request>
//  Execute a saved request
// ─────────────────────────────────────────────────────────────

program
  .command('hit <path>')
  .description('Execute a request  (format: collection/request)')
  .addHelpText('after', '\nExamples:\n  mm hit my-api/get-users\n  mm hit payments/charge')
  .action(async (pathArg) => {
    const { hit } = require('../src/controllers/HitController');
    await hit(pathArg);
  });

// ─────────────────────────────────────────────────────────────
//  mm add <collection/request>
//  Create or edit a request (creates collection if needed)
// ─────────────────────────────────────────────────────────────

program
  .command('add <path>')
  .description('Add or edit a request  (format: collection/request)')
  .addHelpText('after', [
    '',
    'Creates the collection if it does not exist.',
    'If the request already exists, opens it for editing.',
    '',
    'Examples:',
    '  mm add my-api/get-users',
    '  mm add payments/charge',
  ].join('\n'))
  .action(async (pathArg) => {
    const { addRequest } = require('../src/controllers/RequestController');
    await addRequest(pathArg);
  });

// ─────────────────────────────────────────────────────────────
//  mm remove <collection/request>  |  mm remove <collection>
//  Delete a request or an entire collection
// ─────────────────────────────────────────────────────────────

program
  .command('remove <path>')
  .description('Remove a request or an entire collection  (format: collection[/request])')
  .addHelpText('after', [
    '',
    'Examples:',
    '  mm remove my-api/get-users   # remove one request',
    '  mm remove my-api             # remove entire collection',
  ].join('\n'))
  .action(async (pathArg) => {
    const { remove } = require('../src/controllers/RemoveController');
    await remove(pathArg);
  });

// ─────────────────────────────────────────────────────────────
//  mm b-req <collection/request>
//  Open the REQUEST definition in Chrome
// ─────────────────────────────────────────────────────────────

program
  .command('b-req <path>')
  .description('Open the request definition in Chrome  (format: collection/request)')
  .addHelpText('after', [
    '',
    'Shows method, URL (raw + resolved), headers, auth, body and a cURL snippet.',
    '',
    'Example:',
    '  mm b-req my-api/get-users',
  ].join('\n'))
  .action(async (pathArg) => {
    const { beautifyReq } = require('../src/controllers/BeautifyReqController');
    await beautifyReq(pathArg);
  });

// ─────────────────────────────────────────────────────────────
//  mm b-res [collection/request]
//  Open the last RESPONSE in Chrome
// ─────────────────────────────────────────────────────────────

program
  .command('b-res [path]')
  .description('Open the last response in Chrome  (format: collection/request)')
  .addHelpText('after', [
    '',
    'Examples:',
    '  mm b-res                    # last response (any request)',
    '  mm b-res my-api/get-users   # last response for this specific request',
    '  mm b-res /tmp/resp.json     # any JSON file',
  ].join('\n'))
  .action(async (pathArg) => {
    const { beautify } = require('../src/controllers/BeautifyController');
    await beautify(pathArg);
  });

// ─────────────────────────────────────────────────────────────
//  mm history [collection/request]
//  Show global or per-request history
// ─────────────────────────────────────────────────────────────

program
  .command('history [path]')
  .description('Show request history (global last-50, or per request)')
  .addHelpText('after', [
    '',
    'Examples:',
    '  mm history                     # global last 50 (summary table)',
    '  mm history my-api/get-users    # full history for one request (50 entries)',
    '  mm history clear               # clear global history',
  ].join('\n'))
  .action(async (pathArg) => {
    if (pathArg === 'clear') {
      const { clearHistory } = require('../src/controllers/HistoryController');
      await clearHistory();
    } else {
      const { historyCommand } = require('../src/controllers/HistoryController');
      await historyCommand(pathArg);
    }
  });

// ─────────────────────────────────────────────────────────────
//  mm start  /  mm stop   (dashboard server)
// ─────────────────────────────────────────────────────────────

program
  .command('start')
  .description('Start the dashboard server and open it in Chrome')
  .addHelpText('after', '\n  Uses launchctl on macOS if install.sh has been run, otherwise direct spawn.')
  .action(async () => {
    const { startServer } = require('../src/controllers/ServerController');
    await startServer();
  });

program
  .command('stop')
  .description('Stop the running dashboard server')
  .addHelpText('after', '\n  Uses launchctl on macOS if install.sh has been run.')
  .action(async () => {
    const { stopServer } = require('../src/controllers/ServerController');
    await stopServer();
  });

program
  .command('status')
  .description('Show whether the dashboard server is running')
  .action(async () => {
    const { statusServer } = require('../src/controllers/ServerController');
    await statusServer();
  });

// ─────────────────────────────────────────────────────────────
//  mm env  (sub-commands)
// ─────────────────────────────────────────────────────────────

const envCmd = program
  .command('env')
  .description('Manage environments and variables  ({{VAR}} substitution)');

envCmd.command('new <name>').description('Create a new environment')
  .action(async (name) => { const { envNew } = require('../src/controllers/EnvironmentController'); await envNew(name); });

envCmd.command('ls').description('List environments (active one is marked)')
  .action(async () => { const { envList } = require('../src/controllers/EnvironmentController'); await envList(); });

envCmd.command('use <name>').description('Set the active environment')
  .action(async (name) => { const { envUse } = require('../src/controllers/EnvironmentController'); await envUse(name); });

envCmd.command('set <name> <key> <value>').description('Set a variable in an environment')
  .action(async (name, key, value) => { const { envSet } = require('../src/controllers/EnvironmentController'); await envSet(name, key, value); });

envCmd.command('rm <name> [key]').description('Remove an environment or a single key')
  .action(async (name, key) => { const { envRm } = require('../src/controllers/EnvironmentController'); await envRm(name, key); });

envCmd.command('show <name>').description('Print all variables in an environment')
  .action(async (name) => { const { envShow } = require('../src/controllers/EnvironmentController'); await envShow(name); });

// ─────────────────────────────────────────────────────────────
//  mm auth  (sub-commands)
// ─────────────────────────────────────────────────────────────

const authCmd = program
  .command('auth')
  .description('Auth shortcuts — write to the active environment');

authCmd.command('bearer <token>').description('Set Bearer token  →  TOKEN variable')
  .action(async (token) => { const { setBearer } = require('../src/controllers/AuthController'); await setBearer(token); });

authCmd.command('basic <user> <pass>').description('Set Basic auth  →  AUTH_BASIC variable (base64)')
  .action(async (user, pass) => { const { setBasic } = require('../src/controllers/AuthController'); await setBasic(user, pass); });

authCmd.command('apikey <header> <key>').description('Set API key  →  stored in active env')
  .action(async (header, key) => { const { setApiKey } = require('../src/controllers/AuthController'); await setApiKey(header, key); });

// ─────────────────────────────────────────────────────────────
//  mm import <file>
//  Import a Postman collection into mm
// ─────────────────────────────────────────────────────────────

program
  .command('import <file>')
  .description('Import a Postman collection (.json) into mm')
  .addHelpText('after', [
    '',
    'Examples:',
    '  mm import MyAPI.postman_collection.json',
  ].join('\n'))
  .action(async (file) => {
    const { importCollection } = require('../src/controllers/ImportController');
    await importCollection(file);
  });

// ─────────────────────────────────────────────────────────────
//  Server-running gate
//  All commands except start / stop / status require the
//  dashboard server to be up (PID file present + process alive).
// ─────────────────────────────────────────────────────────────

const PID_FILE   = path.join(DATA_DIR, '.mm-server.pid');
const EXEMPT_CMDS = new Set(['start', 'stop', 'status']);

program.hook('preAction', async (_thisCmd, actionCmd) => {
  // Walk up to the root command name (handles `env ls`, `auth bearer`, etc.)
  let cmd = actionCmd;
  while (cmd.parent && cmd.parent !== program) cmd = cmd.parent;
  const rootName = cmd.name();

  if (EXEMPT_CMDS.has(rootName)) return;

  const pidExists = await fs.pathExists(PID_FILE);
  if (!pidExists) {
    console.error(chalk.red('✗  mail-man is not running.'));
    console.error('   Start it with: ' + chalk.cyan('mm start'));
    process.exit(1);
  }

  try {
    const pidData = await fs.readJson(PID_FILE);
    process.kill(pidData.pid, 0);          // throws ESRCH if gone
  } catch {
    console.error(chalk.red('✗  mail-man server is not responding (stale PID).'));
    console.error('   Run ' + chalk.cyan('mm stop') + ' then ' + chalk.cyan('mm start') + ' to restart.');
    process.exit(1);
  }
});

// ─────────────────────────────────────────────────────────────
//  Boot
// ─────────────────────────────────────────────────────────────

(async () => {
  try {
    await ensureDirs();
    await program.parseAsync(process.argv);
  } catch (err) {
    console.error(chalk.red('✗ ') + err.message);
    if (process.env.DEBUG) console.error(err.stack);
    process.exit(1);
  }
})();
